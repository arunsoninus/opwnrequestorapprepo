<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<TableSelectDialog noDataText="{i18n>Billing.Cust.NoData}" title="{i18n>BillingReq.BD.Select.CustomerDialog}"
		liveChange="onSearchCustomerDetails" confirm="onSelectCustomerDetails" cancel="closeCustomerLookup"
		busy="{ReadOnlyModel>/isCustomerLookupBusy}"
		items="{ path : 'CustomerLookup>/results', sorter : { path : 'CustName', descending : false } }">
		<ColumnListItem>
			<cells>
				<ObjectIdentifier title="{CustomerLookup>CustName}"/>
				<Text text="{CustomerLookup>billAddress}"/>
				<Text text="{CustomerLookup>Currency}"/>
			</cells>
		</ColumnListItem>
		<columns>
			<Column>
				<header>
					<Text text="{i18n>Billing.Cust.Details}"/>
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<header>
					<Text text="{i18n>Billing.Cust.Address}"/>
				</header>
			</Column>
			<Column>
				<header>
					<Text text="{i18n>Billing.Cust.Currency}"/>
				</header>
			</Column>
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>