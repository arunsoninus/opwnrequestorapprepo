<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form"
	xmlns:u="sap.ui.unified" xmlns:tnt="sap.tnt">
	<l:VerticalLayout width="100%">
		<l:content>
			<Table inset="false" items="{ path: 'AppModel>/cwsRequest/createCWSRequest/assistanceList', sorter: { path: 'durationYear' } }">
				<headerToolbar>
					<OverflowToolbar>
						<Title class="h3Title" text="{i18n>CwsRequest.Assistance.Note} {AppModel>/cwsRequest/createCWSRequest/REQUEST_TYPE}"/>
						<ToolbarSpacer/>
						<Button icon="sap-icon://add" tooltip="Add Staff/Student" press="onPressAddAssistance" type="Transparent"
							visible="{AppModel>/isFormEditable}"/>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="{i18n>CwsRequest.Assistance.Column1}"/>
					</Column>
					<Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="{i18n>CwsRequest.Assistance.Column2}"/>
					</Column>
					<Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="{i18n>CwsRequest.Assistance.Column3}"/>
					</Column>
					<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline"/>
				</columns>
				<items>
					<ColumnListItem vAlign="Middle">
						<cells>
							<Input value="{AppModel>STAFF_NAME}" editable="{AppModel>/isFormEditable}"/>
							<!--<Text text="{AppModel>STAFF_ID} ({AppModel>STAFF_NUSNET_ID})"/>-->
							<VBox>
								<CWSExtMultiInput placeholder="Select ULU..." dataPath="/d/results" urlAttr="/ChrsFdluUlus?$select=ULU_C,ULU_T" dialogCodeLbl="ULU_T"
									dialogDescLbl="ULU_C" dialogTitle="Select Staff ULU" showValueHelp="true" setOnUI="ULU_T" valueHelpOnly="true"
									valueHelpRequest="lookupValueHelp" value="{AppModel>STAFF_ULU_T}" duplicates="merge" editable="{AppModel>/isFormEditable}"
									valueState="{AppModel>/cwsRequest/validationRequest/uluVState}"/>
								<!--	<Text text="{AppModel>STAFF_ULU_T}"/>-->
							</VBox>
							<!--<Input value="{AppModel>STAFF_ULU}"/>-->
							<VBox>
								<CWSExtMultiInput placeholder="Select FDLU..." dataPath="/d/results" urlAttr="/ChrsFdluUlus?$select=FDLU_C,FDLU_T" dialogCodeLbl="FDLU_T"
									dialogDescLbl="FDLU_C" dialogTitle="Select Staff FDLU" showValueHelp="true" setOnUI="FDLU_T" valueHelpOnly="true"
									valueHelpRequest="lookupValueHelp" value="{AppModel>STAFF_FDLU_T}" duplicates="merge"
									enabled="{= (${AppModel>isFdluEnabled} &amp;&amp; ${AppModel>/isFormEditable})? true : false}"
									valueState="{AppModel>/cwsRequest/validationRequest/fdluVState}"/>
								<!--<Text text="{AppModel>STAFF_FDLU_T}"/>-->
							</VBox>
							<Button icon="sap-icon://delete" press="onPressDeleteAssistance"
								visible="{= ${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS} === '31' ? true : false }"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</l:content>
	</l:VerticalLayout>
</core:FragmentDefinition>