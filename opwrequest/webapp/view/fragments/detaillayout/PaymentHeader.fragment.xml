<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form"
	xmlns:u="sap.ui.unified" xmlns:tnt="sap.tnt" xmlns:rt="sap.ui.richtexteditor">
	<VBox class="sapUiNoMarginTop background">
		<l:Splitter height="400px">
			<List width="100%" items="{ path: 'AppModel>/cwsRequest/createCWSRequest/durationSplitList', sorter: { path: 'YEAR' } }">
				<headerToolbar>
					<OverflowToolbar>
						<Title text="Year Wise Payment" level="H3" class="sapUiSmallMargin"/>
					</OverflowToolbar>
				</headerToolbar>
				<items>
					<ObjectListItem title="{AppModel>YEAR}" type="Navigation" press="onListItemPress"></ObjectListItem>
				</items>
				<layoutData>
					<l:SplitterLayoutData size="200px"/>
				</layoutData>
			</List>
			<Table id="oTableWbs" visible="true" width="100%" fixedLayout="Strict" items="{ path: 'AppModel>/cwsRequest/createCWSRequest/paymentList' }"
				sticky="ColumnHeaders,HeaderToolbar">
				<columns>
					<Column >
						<Text text="Month"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="Amount"/>
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
						<Text text="Status"/>
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
						<Text text="Payment Type"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem vAlign="Middle">
						<cells>
							<ObjectIdentifier title="{parts: [ {path:'AppModel>MONTH'}, {path:'AppModel>YEAR'} ], formatter: '.formatter.displayMonth'}"/>
							<Text text="{path:'AppModel>AMOUNT', formatter: '.formatter.decimalSeparator'}"/>
							<ObjectStatus text="{AppModel>PAYMENT_REQ_STATUS_ALIAS}" state="{AppModel>PAYMENT_REQ_STATUS_STATE}"/>
							<Text text="{AppModel>PAYMENT_TYPE}"/>
						</cells>
					</ColumnListItem>
				</items>
				<layoutData>
					<l:SplitterLayoutData size="auto"/>
				</layoutData>
			</Table>
		</l:Splitter>
	</VBox>
</core:FragmentDefinition>