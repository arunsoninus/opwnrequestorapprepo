<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form"
	xmlns:u="sap.ui.unified" xmlns:tnt="sap.tnt">
	<l:VerticalLayout width="100%">
		<l:content>
			<f:SimpleForm layout="ResponsiveGridLayout" editable="true" maxContainerCols="2" backgroundDesign="Solid" labelSpanL="4" emptySpanL="1"
				emptySpanM="2" emptySpanS="0">
				<f:content>
					<core:Title text="Client and Work Details"/>
					<Label text="University-Level Unit of Engaging Department" required="true"/>
					<VBox>
						<!--Begin of change - CCEV3364-->
						<!--<Text text="{AppModel>/cwsRequest/createCWSRequest/ULU_T}" visible="{AppModel>/isDeptOHRSS}"/>-->
						<!--End of change - CCEV3364-->
						<CWSExtMultiInput placeholder="{i18n>CwsRequest.Faculty.Ph}" dataPath="/d/results" urlAttr="/ChrsFdluUlus?$select=ULU_C,ULU_T"
							dialogCodeLbl="ULU_T" dialogDescLbl="ULU_C" dialogTitle="{i18n>CwsRequest.Faculty.Dialogtitle}" showValueHelp="true" setOnUI="ULU_T"
							valueHelpOnly="true" valueHelpRequest="lookupValueHelp" value="{AppModel>/cwsRequest/createCWSRequest/ULU_T}" duplicates="merge"
							editable="{= (${AppModel>/isUluEnabled} &amp;&amp; ${AppModel>/isFormEditable})? true : false}"
							valueState="{AppModel>/cwsRequest/validationRequest/facultyVState}"/>
						<!--visible="{=!${AppModel>/isDeptOHRSS}}"-->
					</VBox>
					<Label text="Faculty/Department-Level Unit of Engaging Department" required="true"/>
					<!--<Text text="{AppModel>/cwsRequest/createCWSRequest/FDLU_T}"/>-->
					<CWSExtMultiInput placeholder="{i18n>CwsRequest.Department.Ph}" dataPath="/d/results" urlAttr="/ChrsFdluUlus?$select=FDLU_C,FDLU_T"
						dialogCodeLbl="FDLU_T" dialogDescLbl="FDLU_C" dialogTitle="{i18n>CwsRequest.Department.Dialogtitle}" showValueHelp="true" setOnUI="FDLU_T"
						valueHelpOnly="true" valueHelpRequest="lookupValueHelp" value="{AppModel>/cwsRequest/createCWSRequest/FDLU_T}" duplicates="merge"
						editable="{= (${AppModel>/isFdluEnabled} &amp;&amp; ${AppModel>/isFormEditable})? true : false}"
						valueState="{AppModel>/cwsRequest/validationRequest/deptVState}"/>
					<Label text="Location" required="true"/>
					<ComboBox showSecondaryValues="true" placeholder="Select Location.." valueState="{AppModel>/cwsRequest/validationRequest/locationVState}"
						selectedKey="{AppModel>/cwsRequest/createCWSRequest/LOCATION}" items="{AppModel>/locations}" editable="{AppModel>/isFormEditable}"
						change="changeVState">
						<core:Item key="{AppModel>CONFIG_KEY}" text="{AppModel>CONFIG_VALUE}"/>
					</ComboBox>
					<Label text="Program Name" required="true"/>
					<TextArea placeholder="Enter Program Name.." value="{AppModel>/cwsRequest/createCWSRequest/PROGRAM_NAME}" rows="2" maxLength="100"
						editable="{AppModel>/isFormEditable}" valueState="{AppModel>/cwsRequest/validationRequest/programnameVState}"
						liveChange="handleLiveChangeTa" showExceededText="{AppModel>/isFormEditable}"/>
					<Label text="Details of Work" wrapping="true" required="true"/>
					<TextArea placeholder="Enter Details of Work.." value="{AppModel>/cwsRequest/createCWSRequest/WORK_DETAILS}" rows="5" maxLength="2000"
						editable="{AppModel>/isFormEditable}" liveChange="handleLiveChangeTa" showExceededText="{AppModel>/isFormEditable}"
						valueState="{AppModel>/cwsRequest/validationRequest/workDetailsVState}"/>
					<core:Title text="Admin Details"/>
					<Label text="Admin Fees" required="true"/>
					<ComboBox showSecondaryValues="true" placeholder="Select Admin Fees"
						enabled="{=${AppModel>/admitEdit} &amp;&amp; ${AppModel>/isadminDetailsEditAllowed}}"
						selectedKey="{path:'AppModel>/cwsRequest/createCWSRequest/PROPERTY_USAGE'}" items="{AppModel>/levyList}" change="onChangePropertyUsage"
						editable="{AppModel>/isFormEditable}" valueState="{AppModel>/cwsRequest/validationRequest/propertyUsageVState}">
						<core:Item key="{AppModel>CONFIG_KEY}" text="{AppModel>CONFIG_VALUE}"/>
					</ComboBox>
					<Label text="{i18n>waiver}" wrapping="true" visible="{AppModel>/cwsRequest/createCWSRequest/waiverVisible}"/>
					<ComboBox showSecondaryValues="true" placeholder="Select Waiver" enabled="{AppModel>/admitEdit}"
						selectedKey="{AppModel>/cwsRequest/createCWSRequest/IS_WAIVED}" items="{path: 'AppModel>/waiverList', templateShareable:false}"
						editable="{AppModel>/isFormEditable}" visible="{AppModel>/cwsRequest/createCWSRequest/waiverVisible}">
						<core:Item key="{AppModel>CONFIG_KEY}" text="{AppModel>CONFIG_VALUE}"/>
					</ComboBox>
					<Label text=""/>
					<FormattedText
						htmlText="&lt;p&gt;Admin Fees Amount: &lt;strong&gt;{ parts: [{path: 'AppModel>/cwsRequest/createCWSRequest/AMOUNT'},{path: 'AppModel>/cwsRequest/createCWSRequest/IS_WAIVED'},{path:'AppModel>/cwsRequest/createCWSRequest/LEVY_PERCENT'} ], formatter: '.formatter.computeAdminFee' }&lt;/p&gt;"/>
					<!--Begin of change - CCEV3364-->
					<Label text="{i18n>CwsRequest.Approver}"/>
					<ComboBox placeholder="Select Approver" id="idCwDProgramManager" selectionChange="onProgramManagerChange"
						editable="{AppModel>/isFormEditable}" items="{AppModel>/ProgramManagerData}"
						valueState="{AppModel>/cwsRequest/validationRequest/programManagerVState}">
						<core:Item key="{AppModel>STAFF_ID}" text="{AppModel>FULL_NM}"/>
					</ComboBox>
					<Label text=""/>
					<Text text="{AppModel>/APPROVED_BY_FULLNM}" visible="{AppModel>/showApproverText}"/>
					<!--End of change - CCEV3364-->
				</f:content>
			</f:SimpleForm>
		</l:content>
	</l:VerticalLayout>
</core:FragmentDefinition>