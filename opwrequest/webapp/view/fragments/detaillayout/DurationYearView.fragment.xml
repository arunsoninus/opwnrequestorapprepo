<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form"
	xmlns:u="sap.ui.unified" xmlns:tnt="sap.tnt">
	<l:VerticalLayout width="100%">
		<l:content>
			<f:SimpleForm layout="ResponsiveGridLayout" labelSpanL="3" editable="true" maxContainerCols="2" backgroundDesign="Solid">
				<f:content>
					<core:Title text="Dates Selection"/>
					<Label text="Start Date" required="true"/>
					<DatePicker
						value="{ path: 'AppModel>/cwsRequest/createCWSRequest/START_DATE',type: 'sap.ui.model.type.Date', formatOptions: { UTC: true, pattern: 'dd.MM.yyyy' } }"
						displayFormat="dd MMM yyyy" placeholder="Select Start Date.." change="onChangeDatesNDuration"/>
					<Label text="End Date" required="true"/>
					<DatePicker
						value="{ path: 'AppModel>/cwsRequest/createCWSRequest/END_DATE',type: 'sap.ui.model.type.Date', formatOptions: { UTC: true, pattern: 'dd.MM.yyyy' } }"
						displayFormat="dd MMM yyyy" placeholder="Select End Date.." change="onChangeDatesNDuration"/>
					<core:Title/>
					<Label text="Duration of {AppModel>/cwsRequest/createCWSRequest/REQUEST_TYPE}" required="true"/>
					<VBox>
						<Input placeholder="Enter Duration in days..." value="{AppModel>/cwsRequest/createCWSRequest/DURATION_DAYS}" change="onChangeDatesNDuration"/>
						<Text text="(enter in days where 1 day = 8 hrs)"/>
					</VBox>
					<Label text="Total utilization for this year"/>
					<Text text="{AppModel>/cwsRequest/createCWSRequest/DURATION_DAYS}"/>
				</f:content>
			</f:SimpleForm>
			<Table inset="false" items="{ path: 'AppModel>/cwsRequest/createCWSRequest/durationSplitList', sorter: { path: 'YEAR' } }">
				<infoToolbar>
					<Toolbar active=" true">
						<Label text="Duration (in Years)"/>
					</Toolbar>
				</infoToolbar>
				<columns>
					<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="Year"/>
					</Column>
					<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="Start Date"/>
					</Column>
					<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="End Date"/>
					</Column>
					<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="Actual days of {AppModel>/cwsRequest/createCWSRequest/REQUEST_TYPE}" wrapping="true"/>
					</Column>
					<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="Total Utilization (by Year)" wrapping="true"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem vAlign="Middle">
						<cells>
							<ObjectIdentifier title="{AppModel>YEAR}"/>
							<DatePicker value="{ path: 'AppModel>START_DATE',type: 'sap.ui.model.type.Date', formatOptions: { UTC: true, pattern: 'dd.MM.yyyy' } }"
								displayFormat="dd MMM yyyy" editable="false"/>
							<DatePicker value="{ path: 'AppModel>END_DATE',type: 'sap.ui.model.type.Date', formatOptions: { UTC: true, pattern: 'dd.MM.yyyy' } }"
								displayFormat="dd MMM yyyy" editable="false"/>
							<Input value="{AppModel>DURATION}"/>
							<Text text="{AppModel>TOTAL_UTILIZATION_YR}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</l:content>
	</l:VerticalLayout>
</core:FragmentDefinition>