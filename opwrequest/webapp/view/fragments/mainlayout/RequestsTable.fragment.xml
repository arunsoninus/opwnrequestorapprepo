<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:u="sap.uxap"
	xmlns:tnt="sap.tnt">
	<Table id="idOpwnRequestTable" inset="false" growing="true" growingThreshold="50" fixedLayout="Strict"
		items="{ path: 'OpwnSrvModel>/cwsRequestViews', sorter: { path: 'SUBMITTED_ON_TS', descending: true},templateShareable:true}"
		sticky="ColumnHeaders,HeaderToolbar">
		<headerToolbar>
			<OverflowToolbar>
				<Button icon="sap-icon://refresh" text="Refresh" tooltip="Refresh" press="onRefreshClaim" type="Transparent"/>
				<ToolbarSpacer/>
				<SearchField visible="{= ${AppModel>/showSearchField} ? true : false}" id="srchFldCWSRequest" placeholder="Search request.."
					search="onPressSearchCWSRequest" width="20%"/>
				<Button visible="{= ${AppModel>/showSearchField} ? false : true}" tooltip="Add Filter" icon="sap-icon://filter" press="onPressFilterButton"/>
				<Button visible="{= ${AppModel>/showSearchField} ? true : false}" tooltip="Remove Filter" icon="sap-icon://clear-filter"
					press="onPressFilterButton"/>
				<Button icon="sap-icon://sort" press="onPressSortRequest" type="Transparent" visible="true"/>
				<Button tooltip="Group" icon="sap-icon://group-2" press="onPressGroupRequest"/>
			</OverflowToolbar>
		</headerToolbar>
		<columns>
			
			<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" width="2em">
				<Label design="Bold" text=" "/>
			</Column>
			<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" width="9em">
				<Label design="Bold" text="{i18n>CwsRequest.RequestTable.RequestId}"/>
			</Column>
			<Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true" width="8em">
				<Label design="Bold" text="{i18n>CwsRequest.RequestTable.RequestType}" wrapping="true"/>
			</Column>
			<Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true" width="8.5em" visible="{AppModel>/isDepartmentAdmin}">
				<Label design="Bold" text="{i18n>CwsRequest.RequestTable.RequestedFor}"/>
			</Column>
			<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Label design="Bold" text="Start Date"/>
			</Column>
			<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Label design="Bold" text="End Date"/>
			</Column>
			<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Label design="Bold" text="Program Name" wrapping="true"/>
			</Column>
			<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Label design="Bold" text="Amount Payable to Staff" wrapping="true"/>
			</Column>
			<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" width="12em">
				<Label design="Bold" text="Status"/>
			</Column>
			<Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" width="10em">
				<Label design="Bold" text="Submitted On / By"/>
			</Column>
			<Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" width="10em">
				<Label design="Bold" text="{= ${AppModel>/iconTabBarSelectedKey} === 'Draft' ? 'Delete' : 'Options' }"/>
			</Column>
		</columns>
		<items>
			<ColumnListItem type="Active" press="onPressPreviewOpwnRequest">
				<cells>
					<core:Icon src="sap-icon://request" visible="{= ${OpwnSrvModel>SUBMISSION_TYPE} === 'U' ? true : false}" class="sapUiSmallMarginEnd"/>
					<Text text="{OpwnSrvModel>REQUEST_ID}" wrapping="true"/>
					<VBox>
						<Text text="{OpwnSrvModel>PROCESS_TITLE}/"/>
						<Text text="{OpwnSrvModel>SUB_TYPE_T}"/>
					</VBox>
					<VBox visible="{AppModel>/isDepartmentAdmin}">
						<Text text="{OpwnSrvModel>FULL_NM}"/>
					</VBox>
					<Text text="{ path: 'OpwnSrvModel>START_DATE', type: 'sap.ui.model.type.DateTime', formatOptions: { pattern: 'dd MMM, yyyy' } }"/>
					<Text text="{ path: 'OpwnSrvModel>END_DATE', type: 'sap.ui.model.type.DateTime', formatOptions: { pattern: 'dd MMM, yyyy' } }"/>
					<Text text="{OpwnSrvModel>PROGRAM_NAME}"/>
					<Text text="{path:'OpwnSrvModel>AMOUNT',formatter:'.formatter.decimalSeparator' }"/>
					<tnt:InfoLabel text="{=${OpwnSrvModel>STATUS_ALIAS}==='Save As Draft' ? 'Draft': ${OpwnSrvModel>STATUS_ALIAS}}"
						tooltip="{OpwnSrvModel>STATUS_ALIAS}" colorScheme="{OpwnSrvModel>STATUS_COLOR_CODE}" displayOnly="false"/>
					<VBox>
						<Text
							text="{ path: 'OpwnSrvModel>SUBMITTED_ON_TS', type: 'sap.ui.model.type.DateTime', formatOptions: { pattern: 'dd MMM, yyyy HH:mm:ss' } }"/>
						<Text text="{OpwnSrvModel>SUBMITTED_BY_FULLNAME}"/>
					</VBox>
					<HBox>
						<Button icon="sap-icon://delete" tooltip="Delete" press="onPressDeleteDraft"
							visible="{= (${AppModel>/iconTabBarSelectedKey} === 'Draft' &amp;&amp; ${OpwnSrvModel>REQUEST_STATUS} !== '49' &amp;&amp; ${AppModel>/userRole}=== ${i18n>CwsRequest.PrgAdmin}) ? true : false }"/>
						<MenuButton text="Actions" visible="{= ${AppModel>/iconTabBarSelectedKey} === 'Draft' ? false : true }">
							<menu>
								<Menu>
									<MenuItem text="Copy" icon="sap-icon://copy" press="onPressCopy"
										visible="{parts: [ {path:'AppModel>/iconTabBarSelectedKey'}, {path:'OpwnSrvModel>END_DATE'},{path:'OpwnSrvModel>MIGRATED'},{path:'OpwnSrvModel>STAFF_ID'},{path:'AppModel>/appMatrixAuth'},{path:'AppModel>/primaryAssigment/SF_STF_NUMBER'} ], formatter: '.formatter.handleCopyBtnVisibility'}"/>
									<MenuItem text="Track Request" icon="sap-icon://instance" press="onPressShowProcessTracker"/>
									<MenuItem text="Audit Log" icon="sap-icon://display" press="onPressAuditLog"/>
								</Menu>
							</menu>
						</MenuButton>
					</HBox>
				</cells>
			</ColumnListItem>
		</items>
	</Table>
</core:FragmentDefinition>