{
  "_version": "1.82.0",
  "sap.app": {
    "id": "nus.edu.sg.opwrequest",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.4",
      "toolsId": "a23abf46-6e43-4db2-9127-92dd5d298ce9"
    },
    "dataSources": {
      "utilService": {
        "uri": "/v2/util",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/util_metadata.xml",
          "odataVersion": "2.0"
        }
      },
      "catalogService": {
        "uri": "/v2/catalog/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/catalog.xml",
          "odataVersion": "2.0"
        }
      },
      "cwsNedService": {
        "uri": "/odata/v2/cwned/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/catalog.xml",
          "odataVersion": "2.0"
        }
      },
      "local_data_alias": {
        "uri": "enums/localdata.json",
        "type": "JSON"
      }
    },
    "crossNavigation": {
      "inbounds": {
        "opwrequest-Display": {
          "semanticObject": "opwrequest",
          "action": "Display",
          "title": "{{opwrequest-Display.flpTitle}}",
          "subTitle": "{{opwrequest-Display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
        // "sap.suite.ui.commons.statusindicator": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "nus.edu.sg.opwrequest.i18n.i18n"
        }
      },
      "CatalogSrvModel": {
        "dataSource": "catalogService",
        "preload": true,
        "settings": {
          "useBatch": false,
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "UtilitySrvModel": {
        "dataSource": "utilService",
        "preload": true,
        "settings": {
          "useBatch": false,
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "CwsSrvModel": {
        "dataSource": "cwsNedService",
        "preload": true,
        "settings": {
          "useBatch": false,
          "operationMode": "Server",
          "autoExpandSelect": true,
          "synchronizationMode": "None",
          "earlyRequests": true
        }
      },
      "LocalData": {
        "dataSource": "local_data_alias",
        "preload": true,
        "settings": {
          "useBatch": false,
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "nus.edu.sg.opwrequest.view",
        "async": true,
        "transition": "slide",
        "viewPath": "nus.edu.sg.opwrequest.view",
        "controlId": "opwFlexibleColumnLayout"
      },
      "routes": [
        {
          "pattern": ":layout:",
          "name": "master",
          "target": [
            "master",
            "detail"
          ]
        },
        {
          "pattern": "detail/{project}/{layout}",
          "name": "detail",
          "target": [
            "master",
            "detail"
          ]
        },
        {
          "pattern": "taskdetail/{project}/{taskId}/{taskName}/{layout}",
          "name": "taskdetail",
          "target": [
            "master",
            "detail"
          ]
        },
        {
          "pattern": "displaydetail/{project}/{layout}",
          "name": "displaydetail",
          "target": [
            "master",
            "detail"
          ]
        },
        {
          "pattern": "displayofn/{project}/{layout}",
          "name": "displayofn",
          "target": [
            "master",
            "detail"
          ]
        }
      ],
      "targets": {
        "master": {
          "name": "OpwRequestHistory",
          "controlAggregation": "beginColumnPages"
        },
        "detail": {
          "name": "OpwDetailView",
          "controlAggregation": "midColumnPages"
        }
      }
    },
    "rootView": {
      "viewName": "nus.edu.sg.opwrequest.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "opwnrequestorapp"
  }
}