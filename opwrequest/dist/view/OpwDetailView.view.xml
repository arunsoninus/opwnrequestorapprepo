<mvc:View class="sapUiSizeCompact" controllerName="nus.edu.sg.opwrequest.controller.OpwDetailView" xmlns="sap.uxap"
	xmlns:mvc="sap.ui.core.mvc" xmlns:m="sap.m" xmlns:f="sap.f" xmlns:form="sap.ui.layout.form" xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout">
	<m:MessageStrip text="{AppModel>/isClaimLockedMessage}" visible="{= ${AppModel>/isClaimLocked} ? true : false}" showCloseButton="false"
		type="Error" showIcon="true" class="sapUiMediumMarginBottom"></m:MessageStrip>
	<ObjectPageLayout id="objPgLyoutDetlScrn" showTitleInHeaderContent="true" alwaysShowContentHeader="true" preserveHeaderStateOnScroll="false"
		headerContentPinnable="true" isChildPage="true" upperCaseAnchorBar="false" enableLazyLoading="true">
		<headerTitle>
			<ObjectPageDynamicHeaderTitle>
				<breadcrumbs>
					<m:VBox>
						<m:FormattedText class="h4Title"
							htmlText="&lt;p&gt; {AppModel>/cwsRequest/createCWSRequest/REQUEST_TYPE_DESC} submission for &lt;strong&gt; ({AppModel>/cwsRequest/createCWSRequest/statusDisplay}) &lt;/strong&gt; &lt;/p&gt;"/>
						<m:FormattedText class="h4Title"
							htmlText="&lt;p style=color:indianred;font-weight:500;font-size:1.05em;&gt; {AppModel>/durationWarning}&lt;/p&gt;" visible="false"/>
						<m:MessageStrip text="{i18n>CwsRequest.ApproveReject.Display}" visible="{AppModel>/showValidMessage}" showCloseButton="false" type="Error"
							showIcon="true"></m:MessageStrip>
						<m:MessageStrip text="{i18n>CwsRequest.ChangeRequest.Display}" visible="{AppModel>/showChangeReqMessage}" showCloseButton="false"
							type="Error" showIcon="false"></m:MessageStrip>
						<m:MessageStrip text="{i18n>CwsRequest.Request.Complete}" visible="{AppModel>/showCompleteMessage}" showCloseButton="false" type="Success"
							showIcon="false"></m:MessageStrip>
					</m:VBox>
				</breadcrumbs>
				<navigationActions>
					<m:OverflowToolbarButton type="Transparent" icon="sap-icon://full-screen" press="handleFullScreen" id="enterFullScreenBtn"
						tooltip="Enter Full Screen Mode" visible="{= ${/actionButtonsInfo/midColumn/fullScreen} !== null }"/>
					<!--<m:OverflowToolbarButton type="Transparent" icon="sap-icon://exit-full-screen" press="handleExitFullScreen" id="exitFullScreenBtn"-->
					<!--	tooltip="Exit Full Screen Mode" visible="{= ${/actionButtonsInfo/midColumn/exitFullScreen} !== null }"/>-->
					<!--<m:OverflowToolbarButton type="Transparent" icon="sap-icon://decline" press="handleClose" tooltip="Close column"-->
					<!--	visible="{= ${/actionButtonsInfo/midColumn/closeColumn} !== null }"/>-->
					<m:OverflowToolbarButton type="Transparent" icon="sap-icon://exit-full-screen" press="handleExitFullScreen" id="exitFullScreenBtn"
						tooltip="Exit Full Screen Mode" visible="{AppModel>/exitFullScreen}"/>
					<m:OverflowToolbarButton type="Transparent" icon="sap-icon://decline" press="handleClose" tooltip="Close column" visible="false"/>
				</navigationActions>
				<actions>
					<m:Button id="cwsErrorMessagesId" class="removeBorderButton sapUiNoContentPadding" icon="sap-icon://alert" press="onPressErrorMessages"
						tooltip="Error messages" text="{= ${AppModel>/cwsRequest/createCWSRequest/singleRequestErrorMessages/}.length}" type="Reject"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}"
						visible="{= ${AppModel>/cwsRequest/createCWSRequest/singleRequestErrorMessages/}.length > 0 ? true : false}"/>
					<m:Button icon="sap-icon://customer-history" type="Transparent" text="Submission History" tooltip="Submission History"
						press="onPressRequestHistory" visible="{= ${AppModel>/showHistoryButton} === true ? true : false }"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}"/>
					<m:Button icon="sap-icon://delete" text="Delete" type="Transparent" tooltip="Delete" press="onPressDeleteDraft('D')"
						visible="{= ${AppModel>/showDeleteButton} === true ? true : false }" enabled="{= ${AppModel>/isClaimLocked} ? false : true}"/>
					<m:Button id="edit" icon="sap-icon://edit" press="onPressEdit('A')" text="Edit" type="Transparent"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}" visible="{= ${AppModel>/showEditButton} === true ? true : false }"/>
					<m:Button id="editRequest" icon="sap-icon://edit-outside" text="Edit Request" type="Transparent"
						visible="{= (${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '38' &amp;&amp; ${AppModel>/showEditButtonApproved}) ? true : false}"
						press="onPressEditApproved('U')" enabled="{= ${AppModel>/isClaimLocked} ? false : true}"/>
					<m:Button id="update"
						icon="{=${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '46' || ${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '41' || ${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '44' || ${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '45' ?'sap-icon://repost' :'sap-icon://repost'}"
						press="onPressSave"
						text="{=${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '38'? 'Re-Submit': (${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '46' || ${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '41' || ${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '44' || ${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS}=== '45') ? 'Re-Submit' : 'Update'}"
						type="Transparent" enabled="{= ${AppModel>/isClaimLocked} ? false : true}"
						visible="{= ${AppModel>/showUpdateButton} === true ? true : false }"/>
					<m:Button id="cancel" icon="sap-icon://decline" press="onPressCancel" text="Cancel" type="Transparent"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}" visible="{= ${AppModel>/showCancelButton} === true ? true : false }"/>
					<m:Button id="save" icon="sap-icon://save" press="onPressSaveDraftRequest" text="Save" type="Transparent"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}" visible="{= ${AppModel>/showSaveButton} === true ? true : false }"/>
					<m:Button id="submit" icon="sap-icon://activate" press="onPressSubmit" text="Submit" type="Transparent"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}" visible="{= ${AppModel>/showSubmitButton} === true ? true : false }"/>
					<m:Button id="check" icon="sap-icon://accept" press="onPressCheck" text="Check" type="Transparent"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}" visible="{= ${AppModel>/showCheckButton} === true ? true : false }"/>
					<m:Button id="approve" icon="sap-icon://accept" press="onPressApprove" text="Approve" type="Transparent"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}" visible="{= ${AppModel>/showApproveButton} === true ? true : false }"/>
					<m:Button id="reject" icon="sap-icon://decline" press="onPressReject" text="Reject" type="Transparent"
						enabled="{= ${AppModel>/isClaimLocked} ? false : true}" visible="{= ${AppModel>/showRejectButton} === true ? true : false }"/>
					<m:Button id="withdraw" icon="sap-icon://display-more" press="onPressWithdraw" text="Withdraw" type="Transparent"
						visible="{= ${AppModel>/showWithdrawButton} === true ? true : false }" enabled="{= ${AppModel>/isClaimLocked} ? false : true}"/>
					<m:Button id="retract" icon="sap-icon://cause" press="onPressRetract" text="Retract" type="Transparent"
						visible="{= ${AppModel>/showRetractButton} === true ? true : false }" enabled="{= ${AppModel>/isClaimLocked} ? false : true}"/>
					<m:Button icon="sap-icon://inspect-down" type="Reject" text="Close Request" tooltip="Close Request" press="onPressCloseRequest"
						visible="{= ${AppModel>/showCloseButton} === true ? false : false }" enabled="{= ${AppModel>/isClaimLocked} ? false : true}"/>
					<m:Button icon="sap-icon://close-command-field" press="handleClose" tooltip="Exit" text="Exit" visible="true"/>
				</actions>
			</ObjectPageDynamicHeaderTitle>
		</headerTitle>
		<headerContent>
			<m:FlexBox wrap="Wrap" fitContainer="true">
				<m:Avatar class="sapUiSmallMarginEnd" src="{AppModel>/cwsRequest/createCWSRequest/Photo}" displaySize="M"/>
				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
					<m:VBox>
						<m:Text text="{AppModel>/cwsRequest/createCWSRequest/FULL_NM} ({AppModel>/cwsRequest/createCWSRequest/STF_NUMBER})" wrapping="true"/>
						<m:Text text="{AppModel>/cwsRequest/createCWSRequest/DEPT_T} ({AppModel>/cwsRequest/createCWSRequest/DEPT_C})"/>
						<m:Text text="{AppModel>/cwsRequest/createCWSRequest/FACULTY_T} ({AppModel>/cwsRequest/createCWSRequest/FACULTY_C})"/>
					</m:VBox>
				</layout:VerticalLayout>
				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
					<m:VBox>
						<m:Text text="Employee Group: {AppModel>/cwsRequest/createCWSRequest/EMP_GP_T}"/>
						<m:Text text="Date of Joining: {AppModel>/cwsRequest/createCWSRequest/JOIN_DATE}"/>
						<m:Text class="eodRed" text="Official Last Day: {AppModel>/cwsRequest/createCWSRequest/LEAVING_DATE}"
							visible="{=${AppModel>/cwsRequest/createCWSRequest/LEAVING_DATE}=== null ? false : true}"/>
						<m:ObjectStatus title="Request ID"
							text="{AppModel>/cwsRequest/createCWSRequest/REQUEST_ID} ({AppModel>/cwsRequest/createCWSRequest/SUBMISSION_TYPE_T})"
							visible="{= ${AppModel>/cwsRequest/createCWSRequest/REQUEST_STATUS} !== '31' ? true : false }" class="requestid"/>
					</m:VBox>
				</layout:VerticalLayout>
				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd"></layout:VerticalLayout>
				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd"/>
				<layout:VerticalLayout>
					<m:FormattedText visible="false" id="showDraftSavingText"
						htmlText="&lt;p&gt;&lt;strong&gt;Data is &lt;/strong&gt; &lt;em&gt;saving.... &lt;em&gt; &lt;/p&gt;"/>
				</layout:VerticalLayout>
			</m:FlexBox>
		</headerContent>
		<sections>
			<ObjectPageSection id="basic" title="Basic Information">
				<subSections>
					<ObjectPageSubSection>
						<actions>
							<m:Button icon="sap-icon://reset" press="onClear('Info')" visible="{AppModel>/isFormEditable}"/>
						</actions>
						<blocks>
							<core:Fragment fragmentName="nus.edu.sg.opwrequest.view.fragments.detaillayout.BasicInfoView" type="XML"/>
						</blocks>
					</ObjectPageSubSection>
				</subSections>
			</ObjectPageSection>
			<ObjectPageSection title="Client and Work Details">
				<subSections>
					<ObjectPageSubSection>
						<actions>
							<m:Button icon="sap-icon://reset" press="onClear('Client')" visible="{AppModel>/isFormEditable}"/>
						</actions>
						<blocks>
							<core:Fragment fragmentName="nus.edu.sg.opwrequest.view.fragments.detaillayout.ClientAndWorkDetailsView" type="XML"/>
						</blocks>
					</ObjectPageSubSection>
				</subSections>
			</ObjectPageSection>
			<ObjectPageSection title="Payment Details">
				<subSections>
					<ObjectPageSubSection>
						<actions>
							<m:Button icon="sap-icon://reset" press="onClear('Payment')" visible="{AppModel>/isFormEditable}"/>
						</actions>
						<blocks>
							<core:Fragment fragmentName="nus.edu.sg.opwrequest.view.fragments.detaillayout.PaymentTable" type="XML"/>
							<!--<layout:VerticalLayout id="paymentItemVLayout" width="100%" items="{AppModel>/cwsRequest/createCWSRequest}"></blocks>-->
						</blocks>
					</ObjectPageSubSection>
				</subSections>
			</ObjectPageSection>
			<ObjectPageSection title="Attachments">
				<subSections>
					<ObjectPageSubSection>
						<blocks>
							<core:Fragment fragmentName="nus.edu.sg.opwrequest.view.fragments.detaillayout.AttachmentsView" type="XML"/>
						</blocks>
					</ObjectPageSubSection>
				</subSections>
			</ObjectPageSection>
			<ObjectPageSection title="Remarks">
				<subSections>
					<ObjectPageSubSection>
						<blocks>
							<core:Fragment fragmentName="nus.edu.sg.opwrequest.view.fragments.detaillayout.RemarksView" type="XML"/>
						</blocks>
					</ObjectPageSubSection>
				</subSections>
			</ObjectPageSection>
		</sections>
	</ObjectPageLayout>
</mvc:View>