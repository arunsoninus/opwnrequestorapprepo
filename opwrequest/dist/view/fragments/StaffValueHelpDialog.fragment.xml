<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<TableSelectDialog noDataText="No Data Found" title="Enter Employee ID" search=".handleSearchStaffs" confirm=".handleConfirmStaff"
		contentHeight="auto" contentWidth="40%" cancel=".handleCloseStaff" growingThreshold="1000"
		items="{ path : 'AppModel>/staffList', sorter: { path: 'FULL_NM' } }">
		<ColumnListItem vAlign="Middle">
			<cells>
				<Text text="{AppModel>FULL_NM}"/>
			</cells>
		</ColumnListItem>
		<columns>
			<Column minScreenWidth="Desktop" demandPopin="true">
				<header>
					<Label design="Bold"/>
					<!--text="Full Name"-->
				</header>
			</Column>
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>