<core:FragmentDefinition xmlns="sap.m" xmlns:f="sap.ui.layout.form" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core">
	<Dialog title="User's List">
		<content>
			<List items="{ path : 'AppModel>/oFlowProcess/0/userList'}">
				<StandardListItem title="{AppModel>FULL_NM}" description="{AppModel>STAFF_ID} - {AppModel>NUSNET_ID}" type="Active"/>
			</List>
		</content>
		<buttons>
			<Button type="Transparent" text="Close" press=".handleCloseList"/>
		</buttons>
	</Dialog>
</core:FragmentDefinition>