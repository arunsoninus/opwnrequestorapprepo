<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form"
	xmlns:u="sap.ui.unified" xmlns:tnt="sap.tnt" xmlns:rt="sap.ui.richtexteditor">
	<HBox class="sapUiSmallMargin" width="100%">
		<Label required="true" text="WBS:" design="Bold" class="sapUiTinyMarginTop"></Label>
		<VBox width="20%">
			<Input placeholder="Enter WBS.." class="sapUiTinyMarginBegin" change="onChangeWBS" value="{AppModel>WBS}"
				valueState="{= !${AppModel>valueStateWbs} ? 'None' : ${AppModel>valueStateWbs} }"
				valueStateText="{= !${AppModel>valueStateTextWbs} ? '' : ${AppModel>valueStateTextWbs} }"
				editable="{=${AppModel>/isFormEditable} &amp;&amp; ${AppModel>/isWbsChangeAllowed}}"/>
			<Text class="sapUiTinyMarginBegin" text="{AppModel>WBS_Desc}" wrapping="true"/>
		</VBox>
		<Label text="Percentage (%):" design="Bold" class="sapUiTinyMarginTop sapUiSmallMarginBegin"/>
		<StepInput width="35%" placeholder="Enter Percentage.." class="sapUiTinyMarginBegin" value="{AppModel>VALUE}" min="0" max="100" step="1"
			editable="{=${AppModel>/isFormEditable} &amp;&amp; ${AppModel>/isWbsChangeAllowed}}" valueState="{AppModel>/oPercentageVState}"></StepInput>
	</HBox>
</core:FragmentDefinition>