<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form"
	xmlns:uf="sap.ui.unified" xmlns:tnt="sap.tnt">
	<l:VerticalLayout width="100%">
		<l:content>
			<FeedInput class="sapUiSmallMarginTopBottom" placeholder="{i18n>CwsRequest.Remarks.PostFeedPh}"
				maxLength="5000" post="onPostComment" showIcon="true" icon="{AppModel>/staffPhoto}"
				value="{AppModel>/postRemarks}" enabled="{AppModel>/isFormEditable}"/>
			<List growing="true" growingThreshold="4" showSeparators="Inner"
				items="{ path: 'AppModel>/cwsRequest/createCWSRequest/REMARKS', sorter: { path: 'REMARKS_UPDATE_ON', descending: true},templateShareable:true}">
				<FeedListItem showIcon="false" iconDensityAware="false" info="{AppModel>STAFF_USER_TYPE}" sender="{AppModel>STAFF_NAME}"
					text="{AppModel>REMARKS}" timestamp="{ path: 'AppModel>REMARKS_UPDATE_ON',formatter : '.formatter.convertDatesnew' }">
					<actions >
						<FeedListItemAction text="Edit" icon="sap-icon://edit" press="onPressEditRemark"
							visible="{=(${AppModel>oVisible} &amp;&amp; ${AppModel>/isFormEditable})}"/>
						<FeedListItemAction text="Delete" icon="sap-icon://delete" press="onPressDeleteRemark"
							visible="{=(${AppModel>oVisible} &amp;&amp; ${AppModel>/isFormEditable})}"/>
					</actions>
				</FeedListItem>
			</List>
		</l:content>
	</l:VerticalLayout>
</core:FragmentDefinition>