<core:FragmentDefinition xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core" xmlns="sap.m" height="100%" xmlns:l="sap.ui.layout"
	xmlns:u="sap.ui.unified">
	<Dialog showHeader="false" class="sapUiSizeCompact" contentWidth="100%" contentHeight="100%">
		<customHeader>
			<Bar>
				<contentLeft>
					<Title text="Mass Upload Response for {AppModel>/cwsRequest/Request_key_Desc}"/>
				</contentLeft>
				<contentRight>
					<Button text="Export" icon="sap-icon://excel-attachment" press="onExportMassUploadResponse"/>
				</contentRight>
			</Bar>
		</customHeader>
		<MessageStrip text="Please note : Records under Success tab will be saved." type="Information" showIcon="true"
			class="sapUiTinyMarginBeginEnd" visible="false"></MessageStrip>
		<MessageStrip text="{AppModel>/oMassUploadMessage}" type="Error" showIcon="true" class="sapUiTinyMarginBeginEnd"
			visible="{AppModel>/oMassUploadVisible}"></MessageStrip>
		<MessageStrip text="{AppModel>/oMassUploadWMessage}" type="Warning" showIcon="true" class="sapUiTinyMarginBeginEnd"
			visible="{AppModel>/oMassUploadWVisible}"></MessageStrip>
		<MessageStrip text="{AppModel>/oMassUploadSMessage}" type="Success" showIcon="true" class="sapUiTinyMarginBeginEnd"
			visible="{AppModel>/oMassUploadSVisible}"></MessageStrip>
		<content>
			<!--<ScrollContainer height="auto" width="100%" vertical="true" horizontal="true" focusable="false" visible="{AppModel>/oMassVis}">
			</ScrollContainer>
			<VBox visible="{AppModel>/oPreview}">
				<core:Fragment fragmentName="nus.edu.sg.opwrequest.view.fragments.detaillayout.PaymentPreview" type="XML"/>
			</VBox>-->
			<IconTabBar id="itbUpload" upperCase="false" expandable="false" select="onSelectUpload">
				<items>
					<IconTabFilter text="Requests" key="request" tooltip="Requests" icon="sap-icon://activity-items" design="Horizontal">
						<IconTabBar id="itb1" upperCase="false" select="onSelectIconStatus" expandable="false" selectedKey="{AppModel>/oMassSelectedKey}">
							<items>
								<IconTabFilter iconColor="Positive" visible="{AppModel>/oSuVisible}" text="Success" key="Success" tooltip="Success"></IconTabFilter>
								<IconTabFilter iconColor="Critical" visible="{AppModel>/oWrVisible}" tooltip="Warning" text="Warning" key="Warning"></IconTabFilter>
								<IconTabFilter iconColor="Negative" visible="{AppModel>/oErVisible}" tooltip="Error" text="Error" key="Error"></IconTabFilter>
							</items>
							<content>
								<l:Splitter height="500px" width="100%">
									<Table id="fgTableResponse" inset="false" growing="true" growingThreshold="20" growingScrollToLoad="true"
										sticky="ColumnHeaders,HeaderToolbar" items="{ path: 'AppModel>/cwsRequest/createCWSRequest/massUploadFilter', templateShareable:true}">
										<columns>
											<Column width="3.6rem" visible="{=${AppModel>/oErrorlabel}==='Error' }">
												<Label design="Bold" text="Errors"/>
											</Column>
											<Column visible="{=${AppModel>/oErrorlabel}==='Warning' }">
												<Label design="Bold" text=""/>
											</Column>
											<Column width="3rem" hAlign="Center">
												<Label design="Bold" text="S.No"/>
											</Column>
											<Column width="6rem">
												<Label design="Bold" text="Requested For" wrapping="true"/>
											</Column>
											<Column width="6rem">
												<Label design="Bold" text="Sub-Type" wrapping="true"/>
											</Column>
											<Column width="6rem">
												<Label design="Bold" text="Start Date"/>
											</Column>
											<Column width="7rem">
												<Label design="Bold" text="End Date"/>
											</Column>
											<Column width="8rem">
												<Label design="Bold" text="Program Name"/>
											</Column>
											<Column width="5rem">
												<Label design="Bold" text="Amount Payable to Staff" wrapping="true"/>
											</Column>
											<!--<Column width="5rem" hAlign="Center">
							<Label design="Bold" text="Payment Preview" wrapping="true"/>
						</Column>-->
										</columns>
										<items>
											<ColumnListItem type="Active" press="onPressPayPreview">
												<cells>
													<Button class="removeBorderButton sapUiNoContentPadding" icon="sap-icon://alert" text="{= ${AppModel>validationResults/}.length }"
														visible="{= ${AppModel>validationResults/}.length > 0 }" type="Reject" press="onMessagePopoverPress($event,'E')"/>
													<Button class="removeBorderButton sapUiNoContentPadding" icon="sap-icon://alert" text="{= ${AppModel>warningValidationResults/}.length }"
														visible="{= ${AppModel>warningValidationResults/}.length > 0 }" type="Emphasized" press="onMessagePopoverPress($event,'W')"/>
													<Text text="{AppModel>serialNo}"/>
													<Text text="{AppModel>FULL_NAME} ({AppModel>STAFF_ID})"/>
													<Text text="{AppModel>SUB_TYPE_DESC}"/>
													<Text text="{ path: 'AppModel>START_DATE', formatter: '.formatter.dateFormatUTCone'}"/>
													<Text text="{ path: 'AppModel>END_DATE', formatter: '.formatter.dateFormatUTCone'}"/>
													<Text text="{AppModel>program_NAME}"/>
													<Text text="{path:'AppModel>amount',formatter:'.formatter.formatRequestAmount'}"/>
												</cells>
											</ColumnListItem>
										</items>
										<layoutData>
											<l:SplitterLayoutData size="750px"/>
										</layoutData>
									</Table>
									<!--	<List visible="false" width="100%" items="{ path: 'AppModel>/PaymentData/durationSplitList', sorter: { path: 'YEAR' } }">
					<headerToolbar>
						<OverflowToolbar>
							<Title text="Year Wise Payment" level="H3" class="sapUiSmallMargin"/>
						</OverflowToolbar>
					</headerToolbar>
					<items>
						<ObjectListItem title="{AppModel>YEAR}" type="Navigation" press="onListItemPress"></ObjectListItem>
					</items>
					<layoutData>
						<l:SplitterLayoutData size="auto"/>
					</layoutData>
				</List>-->
									<Table id="oTableWbs" visible="true" width="100%" fixedLayout="Strict" items="{ path: 'AppModel>/PaymentData/paymentList' }"
										sticky="ColumnHeaders,HeaderToolbar">
										<columns>
											<Column >
												<Text text="Month"/>
											</Column>
											<Column minScreenWidth="Tablet" demandPopin="true">
												<Text text="Amount"/>
											</Column>
											<Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
												<Text text="Status"/>
											</Column>
											<Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
												<Text text="Payment Type"/>
											</Column>
										</columns>
										<items>
											<ColumnListItem vAlign="Middle">
												<cells>
													<ObjectIdentifier title="{parts: [ {path:'AppModel>MONTH'}, {path:'AppModel>YEAR'} ], formatter: '.formatter.displayMonth'}"/>
													<Text text="{path:'AppModel>AMOUNT', formatter: '.formatter.decimalSeparator'}"/>
													<ObjectStatus text="{AppModel>PAYMENT_REQ_STATUS_ALIAS}" state="{AppModel>PAYMENT_REQ_STATUS_STATE}"/>
													<Text text="{AppModel>PAYMENT_TYPE}"/>
												</cells>
											</ColumnListItem>
										</items>
										<layoutData>
											<l:SplitterLayoutData size="370px"/>
										</layoutData>
									</Table>
								</l:Splitter>
							</content>
						</IconTabBar>
					</IconTabFilter>
					<IconTabSeparator icon="sap-icon://open-command-field"/>
					<IconTabFilter tooltip="Upload Zip" text="Upload Zip" enabled="{=!${AppModel>/oMassUploadVisible}}" key="uploadzip"
						icon="sap-icon://attachment" design="Horizontal">
						<FlexBox class="columns">
							<FormattedText htmlText="{i18n>CwsRequest.AttachZipInfo1}{i18n>CwsRequest.AttachZipInfo2}">
								<layoutData>
									<FlexItemData growFactor="1" baseSize="0" backgroundDesign="Solid" styleClass="sapUiTinyMargin"/>
								</layoutData>
							</FormattedText>
							<Table width="75%" class="tbacronym" items="{AppModel>/attachmentTypes}">
								<headerToolbar>
									<OverflowToolbar>
										<Text class="acronymColor" text="{i18n>Attachment.Acronymtitle}" wrapping="true" />
										<ToolbarSpacer/>
									</OverflowToolbar>
								</headerToolbar>
								<columns>
									<Column>
										<Text text="Document Type"/>
									</Column>
									<Column>
										<Text text="Acronym"/>
									</Column>
								</columns>
								<items>
									<ColumnListItem>
										<cells>
											<Text text="{AppModel>CONFIG_VALUE}"/>
											<Text text="{AppModel>REFERENCE_VALUE}"/>
										</cells>
									</ColumnListItem>
								</items>
								<layoutData>
									<FlexItemData growFactor="1" baseSize="0" backgroundDesign="Solid" styleClass="sapUiTinyMargin"/>
								</layoutData>
							</Table>
						</FlexBox>
						<VBox >
							<Title text="Upload" titleStyle="H5" class="sapUiSmallMarginBegin"/>
							<HBox visible="{AppModel>/massUploader}" class="sapUiSmallMargin sapUiMediumMarginBegin">
								<u:FileUploader width="100%" id="massClaimsUploadZip" placeholder="Upload Mass Requests..." uploadUrl="" fileType="zip"
									typeMissmatch="handlefilezipTypemismatch" fileSizeExceed="handlefilesizeExceed" maximumFileSize="150" value="{ClaimRequest>/massUploadFile}"/>
								<Button text="Upload File" type="Emphasized" press="onUploadZip" class="sapUiSmallMarginBegin"/>
							</HBox>
							<MessageStrip visible="false" class="sapUiLargeMarginTop"></MessageStrip>
							<FormattedText id="uploadMsg" visible="false" class="sapMsgStripError" htmlText="{AppModel>/formattedText}"/>
							<List id="oMassList" mode="Delete" delete="handleDeleteMassAttachment" enableBusyIndicator="true" visible="false">
								<headerToolbar>
									<OverflowToolbar>
										<Title text="Upload Attachments"/>
										<ToolbarSpacer/>
									</OverflowToolbar>
								</headerToolbar>
								<StandardListItem title="{AppModel>/oMassuploadResponse/docName}" description="{AppModel>/oMassuploadResponse/message}"
									icon="sap-icon://attachment-zip-file"/>
							</List>
						</VBox>
					</IconTabFilter>
				</items>
			</IconTabBar>
		</content>
		<buttons>
			<Button icon="sap-icon://activate" text="Submit" press="onPressSavemassrequest"></Button>
			<Button text="Cancel" press="onPressmasscancel('S')"></Button>
		</buttons>
	</Dialog>
</core:FragmentDefinition>