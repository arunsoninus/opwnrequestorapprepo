<mvc:View class="sapUiSizeCompact" controllerName="nus.edu.sg.opwrequest.controller.OpwRequestHistory" xmlns:mvc="sap.ui.core.mvc"
	xmlns:u="sap.uxap" xmlns:layout="sap.ui.layout" xmlns:core="sap.ui.core" xmlns:f="sap.ui.layout.form" xmlns:a="sap.f" displayBlock="true"
	xmlns="sap.m">
	<!--<NavContainer id="claimNav" height="100%" width="100%">-->
	<Page id="cwsMainScreenPageId" showHeader="false" class="sapUiSizeCompact sapUiNoMargin">
		<subHeader>
			<OverflowToolbar>
				<Button icon="sap-icon://grid" press="onNavDashBoard" type="Transparent" tooltip="Dashboard"/>
				<ToolbarSpacer/>
			</OverflowToolbar>
		</subHeader>
		<content>
			<ObjectHeader class="sapUiSizeCompact" responsive="true" icon="{AppModel>/staffPhoto}" imageShape="Circle"
				title="{AppModel>/staffInfo/FULL_NM}" iconDensityAware="false" titleActive="false" titlePress="handleTitlePress" showTitleSelector="true"
				titleSelectorPress="handleQuickViewBtnPress" backgroundDesign="Translucent">
				<headerContainer>
					<IconTabBar id="itb1" selectedKey="{AppModel>/iconTabBarSelectedKey}" upperCase="false" select="onSelectIconFilter" expandable="false">
						<items>
							<IconTabFilter id="itfNew" icon="sap-icon://create" text="New Request" key="New" count=" " tooltip="New Request"
								visible="{=${AppModel>/userRole}=== ${i18n>CwsRequest.PrgAdmin} ? true : false }"></IconTabFilter>
							<IconTabSeparator icon=""/>
							<IconTabFilter id="itfDraft" icon="sap-icon://hint" text="Draft" key="Draft" count=" " tooltip="Draft" iconColor="Marker"></IconTabFilter>
							<IconTabFilter id="itfDeleted" icon="sap-icon://negative" text="Deleted" key="Deleted" count=" " tooltip="Deleted" iconColor="Neutral"></IconTabFilter>
							<IconTabFilter id="itfReject" icon="sap-icon://employee-rejections" count=" " tooltip="Rejected requests" text="Rejected" key="RejReq"
								iconColor="Negative"></IconTabFilter>
							<IconTabFilter id="itfProcess" icon="sap-icon://validate" count=" " tooltip="In Process" text="In Process" key="Process"
								iconColor="Critical"></IconTabFilter>
							<IconTabFilter id="itfPost" icon="sap-icon://complete" count="0" tooltip="Posted" text="Completed" key="Post" iconColor="Positive"></IconTabFilter>
							<IconTabFilter id="itfWithdrawn" icon="sap-icon://not-editable" count=" " tooltip="Withdrawn Requests" text="Withdrawn" key="Withdrawn"
								iconColor="Negative"></IconTabFilter>
							<IconTabFilter id="itfClosedReq" icon="sap-icon://bbyd-active-sales" count="" tooltip="Closed Requests" text="Closed" key="ClosedReq"
								iconColor="Contrast" visible="false"></IconTabFilter>
						</items>
						<content>
							<core:Fragment fragmentName="nus.edu.sg.opwrequest.view.fragments.mainlayout.RequestsTable" type="XML"/>
						</content>
					</IconTabBar>
				</headerContainer>
			</ObjectHeader>
		</content>
	</Page>
</mvc:View>