<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<ViewSettingsDialog confirm="handleConfirm" sortDescending="false" title="View Settings" sortItems="{AppModel>/sortingLookupData}"
		groupItems="{AppModel>/groupLookupData}">
		<sortItems>
			<ViewSettingsItem text="{AppModel>text}" key="{AppModel>key}"
				selected="{= (${AppModel>key} === ${ViewModel>/SortCwTable/sortKey}) ? true : false}"/>
		</sortItems>
		<groupItems>
			<ViewSettingsItem text="{AppModel>text}" key="{AppModel>key}"
				selected="{= (${AppModel>key} === ${ViewModel>/GroupCwTable/groupKey}) ? true : false}"/>
		</groupItems>
	</ViewSettingsDialog>
</core:FragmentDefinition>